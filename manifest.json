{
  "manifest_version": 3,
  "name": "My Custom Ad Blocker",
  "version": "1.0",
  "description": "A custom MV3 ad blocker with dynamic network blocking and cosmetic filtering.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_rules_local",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}